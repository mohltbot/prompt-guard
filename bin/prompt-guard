#!/usr/bin/env node

const { PromptGuard } = require('../dist/index');

async function main() {
  const args = process.argv.slice(2);

  if (args.length === 0) {
    printHelp();
    process.exit(0);
  }

  const [command, ...rest] = args;

  // Detect flags up front so commands can share parsing
  const flags = {};
  const positional = [];
  for (let i = 0; i < rest.length; i++) {
    const a = rest[i];
    if (a === '--verbose' || a === '-v') flags.verbose = true;
    else if (a === '--dry-run') flags.dryRun = true;
    else if (a === '--source' && rest[i + 1]) { flags.source = rest[++i]; }
    else if (a === '--db-path' && rest[i + 1]) { flags.dbPath = rest[++i]; }
    else if (a === '--limit' && rest[i + 1]) { flags.limit = rest[++i]; }
    else if (a === '--per-project' && rest[i + 1]) { flags.perProject = rest[++i]; }
    else if (a === '--top-projects' && rest[i + 1]) { flags.topProjects = rest[++i]; }
    else if (a === '--concurrency' && rest[i + 1]) { flags.concurrency = rest[++i]; }
    else if (a === '--retry-missing') { flags.retryMissing = true; }
    else if (a === '--preview') { flags.preview = true; }
    else if (a === '--mode' && rest[i + 1]) { flags.mode = rest[++i]; }
    else if (a === '--budget' && rest[i + 1]) { flags.budget = rest[++i]; }
    else positional.push(a);
  }
  const promptText = positional.join(' ');

  switch (command) {
    case 'check': {
      const guard = new PromptGuard();
      const results = await guard.check(promptText);
      guard.displayResults(results);
      break;
    }
    case 'enhance': {
      const guard = new PromptGuard();
      const enhanced = await guard.enhance(promptText);
      console.log(enhanced);
      break;
    }
    case 'relevance': {
      const guard = new PromptGuard();
      const { SmartRelevance } = require('../dist/smart-relevance');
      const relevance = new SmartRelevance(guard);
      const report = await relevance.generateRelevanceReport(promptText);
      console.log(report);
      break;
    }
    case 'stats': {
      const guard = new PromptGuard();
      await guard.showStats(promptText || undefined);
      break;
    }
    case 'config': {
      const guard = new PromptGuard();
      guard.showConfig();
      break;
    }
    case 'init': {
      const guard = new PromptGuard();
      await guard.init();
      break;
    }
    case 'ingest': {
      const { runIngest } = require('../dist/commands/ingest');
      await runIngest({
        source: flags.source,
        dryRun: flags.dryRun,
        dbPath: flags.dbPath,
        verbose: flags.verbose,
      });
      break;
    }
    case 'corpus': {
      const sub = positional[0];
      if (sub === 'stats') {
        const { runStats } = require('../dist/commands/stats');
        await runStats({ dbPath: flags.dbPath });
      } else {
        console.error(`Unknown corpus subcommand: ${sub}`);
        console.error('Try: prompt-guard corpus stats');
        process.exit(1);
      }
      break;
    }
    case 'label-llm': {
      const { runLabelLlm } = require('../dist/commands/label-llm');
      await runLabelLlm({
        dryRun: flags.dryRun,
        limit: flags.limit ? parseInt(flags.limit, 10) : undefined,
        perProject: flags.perProject ? parseInt(flags.perProject, 10) : undefined,
        topProjects: flags.topProjects ? parseInt(flags.topProjects, 10) : undefined,
        concurrency: flags.concurrency ? parseInt(flags.concurrency, 10) : undefined,
        retryMissing: flags.retryMissing,
        dbPath: flags.dbPath,
      });
      break;
    }
    case 'backfill-reasons': {
      const { runBackfillReasons } = require('../dist/commands/backfill-reasons');
      await runBackfillReasons({ dbPath: flags.dbPath });
      break;
    }
    case 'label-gold': {
      const { runLabelGold } = require('../dist/commands/label-gold');
      await runLabelGold({
        preview: flags.preview,
        limit: flags.limit ? parseInt(flags.limit, 10) : undefined,
        dbPath: flags.dbPath,
      });
      break;
    }
    case 'dedupe-prompts': {
      const { runDedupePrompts } = require('../dist/commands/dedupe-prompts');
      await runDedupePrompts({ dryRun: flags.dryRun, dbPath: flags.dbPath });
      break;
    }
    case 'learn': {
      const { runLearn } = require('../dist/commands/learn');
      await runLearn({ prompt: promptText, dbPath: flags.dbPath });
      break;
    }
    case 'eval': {
      const { runEval } = require('../dist/commands/eval');
      await runEval({
        mode: flags.mode || 'gold',
        dbPath: flags.dbPath,
        budgetUsd: flags.budget ? parseFloat(flags.budget) : 2.0,
      });
      break;
    }
    default:
      console.error(`Unknown command: ${command}`);
      printHelp();
      process.exit(1);
  }
}

function printHelp() {
  console.log('Usage: prompt-guard <command> [options]');
  console.log('');
  console.log('Prompt commands:');
  console.log('  check <prompt>     Check a prompt for missing context');
  console.log('  enhance <prompt>   Enhance prompt with context from .md files');
  console.log('  relevance <prompt> Show context relevance scoring');
  console.log('  stats [prompt]     Show prompt and context statistics');
  console.log('  config             Show current configuration');
  console.log('  init               Initialize prompt-guard in current project');
  console.log('');
  console.log('Corpus commands:');
  console.log('  ingest [--source claude-code|cowork|all] [--verbose]');
  console.log('                     Ingest existing JSONL corpora into ~/.prompt-guard/corpus.db');
  console.log('  corpus stats       Inspect ingested corpus + sample-check hygiene filters');
  console.log('  label-llm [--dry-run] [--per-project N] [--top-projects N] [--limit N]');
  console.log('                     Run LLM extractor over rule-extracted clarifying pairs.');
  console.log('                     Use --dry-run to print verdicts without DB writes.');
  console.log('');
  console.log('Options:');
  console.log('  --db-path <path>   Override DB path (default ~/.prompt-guard/corpus.db)');
  console.log('  --verbose | -v     Print per-file progress');
  console.log('');
  console.log('Examples:');
  console.log('  prompt-guard ingest --source all');
  console.log('  prompt-guard corpus stats');
}

main().catch(err => {
  console.error(err);
  process.exit(1);
});
